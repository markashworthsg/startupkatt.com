APP_NAME="Startup Katt"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://startupkatt.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# SQLite by default so you can run with zero database setup.
# Switch to mysql for production if you prefer.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=startupkatt
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@startupkatt.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# Startup Katt: comic ingestion settings
# ─────────────────────────────────────────────
# Folder you drop new comic image files into. Leave blank to use the
# default: storage/app/comics/incoming
COMICS_INCOMING_PATH=

# First release slot when there are no scheduled comics (or we've fallen
# behind): "today" or "tomorrow".
COMICS_FIRST_SLOT=today

# Move files out of the incoming folder after import (true) or leave them
# in place and rely on the hash de-dupe (false).
COMICS_MOVE_AFTER_IMPORT=true

# ─────────────────────────────────────────────
# beehiiv (newsletter / hybrid): fill in when ready, safe to leave blank
# ─────────────────────────────────────────────
BEEHIIV_PUBLICATION_ID=
BEEHIIV_API_KEY=
BEEHIIV_FORM_ID=
BEEHIIV_EMBED_URL=
BEEHIIV_PUBLICATION_URL=

# ─────────────────────────────────────────────
# Telegram channel (push distribution). Blank = off, the daily
# comics:post-telegram run becomes a clean no-op.
# ─────────────────────────────────────────────
# 1. Create a bot with @BotFather, paste the token below.
# 2. Add that bot to the channel as an ADMIN with "Post Messages".
#    A bot cannot post to a channel it does not administer.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=@startupkatt
# How many days back a normal run looks for unposted strips (covers a missed
# cron run without ever dredging up the archive), and the per-run throttle.
TELEGRAM_CATCH_UP_DAYS=3
TELEGRAM_MAX_PER_RUN=5

# ─────────────────────────────────────────────
# Analytics (Plausible: cookieless, no consent banner). Leave the domain
# blank to disable entirely (no script, no third-party request). Set it to
# your Plausible property name (the bare host) to switch analytics on.
# ─────────────────────────────────────────────
PLAUSIBLE_DOMAIN=
# Override only for self-hosting, a proxy/custom domain, or an extended
# script. Defaults to Plausible Cloud; custom events work as-is.
PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Google Search Console: paste the token from the URL-prefix property's
# "HTML tag" verification method (just the content="..." value). Blank = off.
GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────
# Admin metadata editor (/admin)
# ─────────────────────────────────────────────
# Single HTTP Basic credential. Leave ADMIN_PASSWORD blank to keep /admin
# locked (returns 403). Set both to edit a comic's title / alt text / caption /
# description and override its release date.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Secret sneak-peek of scheduled strips at /preview/{token}. Blank = disabled.
COMICS_PREVIEW_TOKEN=
